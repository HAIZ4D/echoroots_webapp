## 8. Service Layer Interface Signatures

### `gemini.js` вҖ” Gemini API Facade

```javascript
import { GoogleGenerativeAI } from '@google/generative-ai';

const genAI = new GoogleGenerativeAI(import.meta.env.VITE_GEMINI_API_KEY);
const model = genAI.getGenerativeModel({ model: 'gemini-2.0-flash' });

/**
 * Transcribe audio blob to text using Gemini multimodal.
 * Converts blob вҶ’ base64, sends as inline audio part.
 */
export async function transcribeAudio(audioBlob)
// вҶ’ { transcription: string, language: string, confidence: number }

/**
 * Translate text from source language to multiple targets.
 * Includes cultural annotations for nuanced terms.
 */
export async function translateText(text, sourceLang, targetLangs)
// вҶ’ { translations: [{ lang: string, text: string, culturalNotes: string }] }

/**
 * Split a story into 3вҖ“5 illustrated scenes.
 * Returns scene text, translation, and Imagen-ready image prompts.
 */
export async function splitIntoScenes(storyText, translation)
// вҶ’ { scenes: [{ sceneNumber: number, text: string, translation: string, imagePrompt: string }] }

/**
 * Generate an illustration via Imagen 3.
 * Returns a base64 image or a Firebase Storage URL after upload.
 */
export async function generateIllustration(prompt)
// вҶ’ { imageBase64: string, mimeType: string }

/**
 * Generate a vector embedding for RAG retrieval.
 */
export async function generateEmbedding(text)
// вҶ’ { embedding: number[] }   (768-dim vector)

/**
 * Generate a RAG-grounded response given a query and context docs.
 * Injects the Digital Elder system prompt.
 */
export async function generateRAGResponse(query, contextDocs)
// вҶ’ { answer: string, vocabTerms: [{ word: string, meaning: string }] }

/**
 * Evaluate user pronunciation against a reference phrase.
 */
export async function evaluatePronunciation(userAudioBlob, referencePhrase)
// вҶ’ { score: number, feedback: string, tips: string[] }
```

### `elevenlabs.js` вҖ” ElevenLabs TTS

```javascript
const API_KEY = import.meta.env.VITE_ELEVENLABS_API_KEY;
const VOICE_ID = import.meta.env.VITE_ELEVENLABS_VOICE_ID;

/**
 * REST-based TTS for scene narration (StoryWeaver).
 * Returns audio blob for download/playback.
 */
export async function textToSpeech(text, voiceId = VOICE_ID)
// вҶ’ { audioBlob: Blob, audioUrl: string }

/**
 * Initialize a WebSocket connection for streaming TTS to TalkingHead.
 * Returns a WebSocket instance that pushes audio chunks + word timestamps.
 */
export function initWebSocket(voiceId = VOICE_ID)
// вҶ’ WebSocket (ready for TalkingHead.speakWithAudio())
```

### `avatar.js` вҖ” TalkingHead Wrapper

```javascript
/**
 * Initialize TalkingHead in a container element.
 * Loads GLB avatar + Mixamo animations + configures ElevenLabs lip-sync.
 */
export async function initAvatar(containerElement, options = {})
// вҶ’ TalkingHead instance

/**
 * Make the avatar speak text with lip-sync via ElevenLabs WebSocket.
 */
export async function speak(talkingHead, text)
// вҶ’ void (avatar lip-syncs in real-time)

/**
 * Stop any current speech.
 */
export function stopSpeaking(talkingHead)
// вҶ’ void

/**
 * Play a named animation (Idle, Talking, Greeting).
 */
export async function playAnimation(talkingHead, animationName)
// вҶ’ void

/**
 * Get current avatar state.
 */
export function getAvatarState(talkingHead)
// вҶ’ { isSpeaking: boolean, currentAnimation: string }
```

### `rag.js` вҖ” Full RAG Pipeline

```javascript
import { generateEmbedding, generateRAGResponse } from './gemini';
import { db } from './firebase';

/**
 * Full RAG pipeline: embed вҶ’ search вҶ’ augment вҶ’ generate.
 * Returns answer with vocabulary terms and source documents.
 */
export async function queryKnowledgeBase(question)
// вҶ’ { answer: string, sources: Document[], vocabTerms: VocabTerm[] }

/**
 * Seed Firestore with cultural knowledge from seedKnowledge.json.
 * Computes embeddings for each entry and stores them.
 */
export async function seedKnowledgeBase(entries)
// вҶ’ { seededCount: number }
```

### `storyPipeline.js` вҖ” StoryWeaver Orchestrator

```javascript
import { transcribeAudio, translateText, splitIntoScenes, generateIllustration } from './gemini';
import { textToSpeech } from './elevenlabs';

/**
 * Orchestrates the full StoryWeaver pipeline.
 * Calls onProgress(stage, data) at each step for UI updates.
 * 
 * Stages: 'recording' вҶ’ 'transcribing' вҶ’ 'translating' вҶ’ 
 *         'splitting' вҶ’ 'illustrating' вҶ’ 'narrating' вҶ’ 'assembling' вҶ’ 'complete'
 */
export async function processStory(audioBlob, onProgress)
// вҶ’ {
//     transcription: string,
//     language: string,
//     translations: [{ lang: string, text: string }],
//     scenes: [{
//       sceneNumber: number,
//       originalText: string,
//       translationEn: string,
//       translationMs: string,
//       imageBase64: string,
//       audioBlob: Blob,
//       culturalNote: string
//     }],
//     metadata: { language: string, duration: number, createdAt: Date }
//   }
```

