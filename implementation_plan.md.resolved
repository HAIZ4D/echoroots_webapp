## 10. State Management (Zustand Store Shape)

```javascript
// stores/appStore.js
import { create } from 'zustand';

const useAppStore = create((set, get) => ({
  // в”Җв”Җв”Җ Session в”Җв”Җв”Җ
  sessionId: crypto.randomUUID(),

  // в”Җв”Җв”Җ StoryWeaver Pipeline в”Җв”Җв”Җ
  pipeline: {
    stage: 'idle',           // idle | recording | transcribing | translating | splitting | illustrating | narrating | assembling | complete | error
    progress: 0,             // 0вҖ“100%
    transcription: null,
    translations: [],
    scenes: [],
    error: null,
  },
  setPipelineStage: (stage, data) => set((s) => ({
    pipeline: { ...s.pipeline, stage, ...data }
  })),
  resetPipeline: () => set({ pipeline: { stage: 'idle', progress: 0, transcription: null, translations: [], scenes: [], error: null } }),

  // в”Җв”Җв”Җ Digital Elder Chat в”Җв”Җв”Җ
  chatMessages: [],          // [{ role: 'user'|'elder', text, vocabTerms?, sources?, timestamp }]
  addChatMessage: (msg) => set((s) => ({
    chatMessages: [...s.chatMessages, { ...msg, timestamp: Date.now() }]
  })),
  clearChat: () => set({ chatMessages: [] }),

  // в”Җв”Җв”Җ Avatar в”Җв”Җв”Җ
  avatarReady: false,
  avatarSpeaking: false,
  setAvatarReady: (ready) => set({ avatarReady: ready }),
  setAvatarSpeaking: (speaking) => set({ avatarSpeaking: speaking }),

  // в”Җв”Җв”Җ Story Archive в”Җв”Җв”Җ
  savedStories: [],
  addSavedStory: (story) => set((s) => ({
    savedStories: [story, ...s.savedStories]
  })),

  // в”Җв”Җв”Җ Pronunciation Lab в”Җв”Җв”Җ
  pronunciationProgress: {
    wordsAttempted: 0,
    wordsCorrect: 0,
    streak: 0,
    history: [],
  },
  updatePronunciationProgress: (result) => set((s) => ({
    pronunciationProgress: {
      ...s.pronunciationProgress,
      wordsAttempted: s.pronunciationProgress.wordsAttempted + 1,
      wordsCorrect: result.score >= 70
        ? s.pronunciationProgress.wordsCorrect + 1
        : s.pronunciationProgress.wordsCorrect,
      streak: result.score >= 70
        ? s.pronunciationProgress.streak + 1
        : 0,
      history: [...s.pronunciationProgress.history, result],
    }
  })),

  // в”Җв”Җв”Җ UI State в”Җв”Җв”Җ
  isLoading: false,
  setLoading: (loading) => set({ isLoading: loading }),
}));

export default useAppStore;
```

---

## 11. API Integration Map

| Service Module | External API | Trigger | Data Flow |
|---------------|-------------|---------|-----------|
| `gemini.js` вҶ’ `transcribeAudio()` | Gemini 2.0 Flash (multimodal) | User stops recording | audioBlob вҶ’ base64 вҶ’ Gemini вҶ’ transcription text |
| `gemini.js` вҶ’ `translateText()` | Gemini 2.0 Flash | After transcription | text вҶ’ Gemini вҶ’ translations array |
| `gemini.js` вҶ’ `splitIntoScenes()` | Gemini 2.0 Flash | After translation | story text вҶ’ Gemini вҶ’ scene objects with image prompts |
| `gemini.js` вҶ’ `generateIllustration()` | Imagen 3 (via Gemini) | For each scene | image prompt вҶ’ Imagen 3 вҶ’ base64 image |
| `gemini.js` вҶ’ `generateEmbedding()` | Gemini Embedding | User asks question / seed time | text вҶ’ Gemini вҶ’ 768-dim vector |
| `gemini.js` вҶ’ `generateRAGResponse()` | Gemini 2.0 Flash | After context assembled | query + docs вҶ’ Gemini вҶ’ grounded answer |
| `gemini.js` вҶ’ `evaluatePronunciation()` | Gemini 2.0 Flash | User records pronunciation | audioBlob + phrase вҶ’ Gemini вҶ’ score + feedback |
| `elevenlabs.js` вҶ’ `textToSpeech()` | ElevenLabs REST | Scene narration (StoryWeaver) | text вҶ’ ElevenLabs вҶ’ audioBlob |
| `elevenlabs.js` вҶ’ `initWebSocket()` | ElevenLabs WebSocket | Avatar speaks (Digital Elder) | text вҶ’ WS вҶ’ chunked audio + timestamps |
| `avatar.js` вҶ’ `speak()` | TalkingHead + ElevenLabs WS | RAG answer ready | text вҶ’ TalkingHead вҶ’ lip-synced 3D avatar |
| `firebase.js` вҶ’ Firestore | Cloud Firestore | Save story / query KB | CRUD + vector search |
| `firebase.js` вҶ’ Storage | Firebase Storage | Save audio/images | File upload/download |

